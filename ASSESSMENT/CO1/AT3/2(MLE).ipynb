      "source": [
        "import numpy as np\n",
        "\n",
        "np.random.seed(1)\n",
        "\n",
        "data = np.random.normal(50, 5, 100)\n",
        "\n",
        "mean = np.mean(data)\n",
        "variance = np.var(data)\n",
        "\n",
        "print(\"Estimated Mean =\", round(mean, 2))\n",
        "print(\"Estimated Variance =\", round(variance, 2))"
      ],
