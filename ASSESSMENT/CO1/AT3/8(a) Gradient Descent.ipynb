        "x = 5\n",
        "learning_rate = 0.1\n",
        "\n",
        "for i in range(5):\n",
        "    gradient = 2 * x\n",
        "    x = x - learning_rate * gradient\n",
        "    print(\"Iteration\", i + 1, \"Value =\", round(x, 2))"
