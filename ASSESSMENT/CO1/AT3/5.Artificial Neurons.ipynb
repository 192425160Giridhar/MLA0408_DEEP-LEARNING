      "source": [
        "import numpy as np\n",
        "\n",
        "x = np.array([-2, -1, 0, 1, 2])\n",
        "\n",
        "sigmoid = 1 / (1 + np.exp(-x))\n",
        "relu = np.maximum(0, x)\n",
        "\n",
        "print(\"Sigmoid Output\")\n",
        "print(sigmoid)\n",
        "\n",
        "print(\"\\nReLU Output\")\n",
        "print(relu)"
      ],
