      "source": [
        "from sklearn.linear_model import Perceptron\n",
        "from sklearn.datasets import load_iris\n",
        "\n",
        "data = load_iris()\n",
        "\n",
        "X = data.data[:100]\n",
        "y = data.target[:100]\n",
        "\n",
        "model = Perceptron()\n",
        "model.fit(X, y)\n",
        "\n",
        "print(\"Perceptron Trained Successfully\")"
      ],
